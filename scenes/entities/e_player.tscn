; Player entity scene  —  e_player.tscn
;
; Root:   Player (CharacterBody2D, extends HumanBase)
; Children:
;   CollisionShape2D  – capsule hitbox (radius 10, height 24)
;   BodySprite        – Sprite2D body visual (ball_right.png)
;   AimPivot          – Node2D; rotated each frame by HumanBase to follow mouse
;     RightHand       – Node2D weapon/primary-hand mount  (x=16, y=0)
;       HandSprite    – Sprite2D hand visual
;     LeftHand        – Node2D off-hand mount             (x=10, y=-6)
;       HandSprite    – Sprite2D hand visual
;
; The ECS bridge entity (PlayerECSState) is added at runtime by Player._setup_ecs_entity().
; Gameplay state (C_Health, C_Stamina, C_CombatState, etc.) lives in that child entity.

[gd_scene format=3 uid="uid://pe_player_scene_1"]

[ext_resource type="Script" path="res://scripts/entities/gameplay/e_player.gd" id="1_player"]
[ext_resource type="Texture2D" uid="uid://ca6gr7lukemuk" path="res://assets/game/textures/entities/ball/ball_right.png" id="2_ball_r"]
[ext_resource type="Texture2D" uid="uid://gtnpwtfb288i" path="res://assets/game/textures/entities/ball/ball_hand.png" id="3_hand"]

[sub_resource type="CapsuleShape2D" id="CapsuleShape2D_player"]
radius = 10.0
height = 24.0

; ── Root ──────────────────────────────────────────────────────────────────────
[node name="Player" type="CharacterBody2D"]
script = ExtResource("1_player")

; ── Physics hitbox ────────────────────────────────────────────────────────────
[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("CapsuleShape2D_player")

; ── Body visual ───────────────────────────────────────────────────────────────
; ball_right.png faces right (0°), matching the default aim direction Vector2.RIGHT.
[node name="BodySprite" type="Sprite2D" parent="."]
texture = ExtResource("2_ball_r")

; ── Aim rig ───────────────────────────────────────────────────────────────────
; AimPivot sits at the body centre (0,0). HumanBase rotates it each physics frame
; to face the mouse cursor (via Player._get_aim_direction()).
[node name="AimPivot" type="Node2D" parent="."]

; Right hand — primary weapon hand; positioned 16 px outward along the aim axis.
; Attach weapons here via HumanBase.attach_weapon().
[node name="RightHand" type="Node2D" parent="AimPivot"]
position = Vector2(16, 0)

[node name="HandSprite" type="Sprite2D" parent="AimPivot/RightHand"]
texture = ExtResource("3_hand")

; Left hand — off-hand / secondary item mount; positioned slightly inward and offset.
[node name="LeftHand" type="Node2D" parent="AimPivot"]
position = Vector2(10, -6)

[node name="HandSprite" type="Sprite2D" parent="AimPivot/LeftHand"]
texture = ExtResource("3_hand")
