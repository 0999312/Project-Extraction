[gd_resource type="Theme" format=3 uid="uid://minimal_vector_theme"]

; ── Palette ────────────────────────────────────────────────────────────────────
; BG_DARK   #0A0A0A   Color(0.039, 0.039, 0.039, 1)
; FG_LIGHT  #F0F0F0   Color(0.941, 0.941, 0.941, 1)
; ACCENT    #00E5FF   Color(0, 0.898, 1, 1)
; HOVER_BG  #F0F0F0   (inverted)
; PRESSED   #444444   Color(0.267, 0.267, 0.267, 1)
; DISABLED  #2A2A2A   Color(0.165, 0.165, 0.165, 1)
; BORDER    2 px, hard edges, zero corner radius

; ── StyleBoxes ─────────────────────────────────────────────────────────────────

; Button / normal
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_normal"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.039, 0.039, 0.039, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.941, 0.941, 0.941, 1)

; Button / hover  (invert: white bg, black text)
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_hover"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.941, 0.941, 0.941, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.039, 0.039, 0.039, 1)

; Button / pressed  (offset illusion: thicker bottom/right border)
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_pressed"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.267, 0.267, 0.267, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0, 0.898, 1, 1)

; Button / disabled
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_disabled"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.165, 0.165, 0.165, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.4, 0.4, 0.4, 1)

; Button / focus ring
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_focus"]
bg_color = Color(0, 0, 0, 0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0, 0.898, 1, 1)
expand_margin_left = 2.0
expand_margin_top = 2.0
expand_margin_right = 2.0
expand_margin_bottom = 2.0

; Panel / generic container
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
content_margin_left = 4.0
content_margin_top = 4.0
content_margin_right = 4.0
content_margin_bottom = 4.0
bg_color = Color(0.039, 0.039, 0.039, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.941, 0.941, 0.941, 1)

; PanelContainer / inner container (no border, just background)
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel_container"]
content_margin_left = 4.0
content_margin_top = 4.0
content_margin_right = 4.0
content_margin_bottom = 4.0
bg_color = Color(0.059, 0.059, 0.059, 1)

; ProgressBar / background track
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_progress_bg"]
bg_color = Color(0.039, 0.039, 0.039, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.941, 0.941, 0.941, 1)

; ProgressBar / fill (accent cyan — used as default; HUD overrides per bar)
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_progress_fill"]
bg_color = Color(0, 0.898, 1, 1)

; LineEdit / normal
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_lineedit_normal"]
content_margin_left = 4.0
content_margin_top = 4.0
content_margin_right = 4.0
content_margin_bottom = 4.0
bg_color = Color(0.039, 0.039, 0.039, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.941, 0.941, 0.941, 1)

; LineEdit / focus
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_lineedit_focus"]
content_margin_left = 4.0
content_margin_top = 4.0
content_margin_right = 4.0
content_margin_bottom = 4.0
bg_color = Color(0.039, 0.039, 0.039, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0, 0.898, 1, 1)

; TabContainer / panel
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_tab_panel"]
content_margin_left = 4.0
content_margin_top = 4.0
content_margin_right = 4.0
content_margin_bottom = 4.0
bg_color = Color(0.039, 0.039, 0.039, 1)

; TabContainer / tab selected
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_tab_selected"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.941, 0.941, 0.941, 1)
border_width_bottom = 2
border_color = Color(0, 0.898, 1, 1)

; TabContainer / tab unselected
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_tab_unselected"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.039, 0.039, 0.039, 1)

; TabContainer / tab hovered
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_tab_hovered"]
content_margin_left = 6.0
content_margin_top = 4.0
content_margin_right = 6.0
content_margin_bottom = 4.0
bg_color = Color(0.165, 0.165, 0.165, 1)

; ScrollBar grabber
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_scrollbar_grabber"]
bg_color = Color(0.941, 0.941, 0.941, 1)

; ScrollBar grabber highlight
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_scrollbar_grabber_hl"]
bg_color = Color(0, 0.898, 1, 1)

; ScrollBar grabber pressed
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_scrollbar_grabber_pressed"]
bg_color = Color(0.267, 0.267, 0.267, 1)

; ScrollBar track
[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_scrollbar_track"]
bg_color = Color(0.039, 0.039, 0.039, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.3, 0.3, 0.3, 1)

[sub_resource type="StyleBoxEmpty" id="StyleBoxEmpty_blank"]

; ── Theme Resource ─────────────────────────────────────────────────────────────
[resource]

; ── Button ──
Button/colors/font_color = Color(0.941, 0.941, 0.941, 1)
Button/colors/font_hover_color = Color(0.039, 0.039, 0.039, 1)
Button/colors/font_pressed_color = Color(0, 0.898, 1, 1)
Button/colors/font_focus_color = Color(0.941, 0.941, 0.941, 1)
Button/colors/font_disabled_color = Color(0.4, 0.4, 0.4, 1)
Button/colors/font_hover_pressed_color = Color(0, 0.898, 1, 1)
Button/styles/normal = SubResource("StyleBoxFlat_btn_normal")
Button/styles/hover = SubResource("StyleBoxFlat_btn_hover")
Button/styles/pressed = SubResource("StyleBoxFlat_btn_pressed")
Button/styles/disabled = SubResource("StyleBoxFlat_btn_disabled")
Button/styles/focus = SubResource("StyleBoxFlat_btn_focus")

; ── Panel ──
Panel/styles/panel = SubResource("StyleBoxFlat_panel")

; ── PanelContainer ──
PanelContainer/styles/panel = SubResource("StyleBoxFlat_panel_container")

; ── ProgressBar ──
ProgressBar/colors/font_color = Color(0.941, 0.941, 0.941, 1)
ProgressBar/styles/background = SubResource("StyleBoxFlat_progress_bg")
ProgressBar/styles/fill = SubResource("StyleBoxFlat_progress_fill")

; ── Label ──
Label/colors/font_color = Color(0.941, 0.941, 0.941, 1)

; ── LineEdit ──
LineEdit/colors/font_color = Color(0.941, 0.941, 0.941, 1)
LineEdit/colors/font_placeholder_color = Color(0.5, 0.5, 0.5, 1)
LineEdit/colors/cursor_color = Color(0, 0.898, 1, 1)
LineEdit/colors/selection_color = Color(0, 0.898, 1, 0.4)
LineEdit/styles/normal = SubResource("StyleBoxFlat_lineedit_normal")
LineEdit/styles/focus = SubResource("StyleBoxFlat_lineedit_focus")
LineEdit/styles/read_only = SubResource("StyleBoxFlat_btn_disabled")

; ── TabContainer ──
TabContainer/colors/font_selected_color = Color(0.039, 0.039, 0.039, 1)
TabContainer/colors/font_unselected_color = Color(0.941, 0.941, 0.941, 1)
TabContainer/colors/font_hovered_color = Color(0, 0.898, 1, 1)
TabContainer/colors/font_disabled_color = Color(0.4, 0.4, 0.4, 1)
TabContainer/styles/panel = SubResource("StyleBoxFlat_tab_panel")
TabContainer/styles/tab_selected = SubResource("StyleBoxFlat_tab_selected")
TabContainer/styles/tab_unselected = SubResource("StyleBoxFlat_tab_unselected")
TabContainer/styles/tab_hovered = SubResource("StyleBoxFlat_tab_hovered")
TabContainer/styles/tab_focus = SubResource("StyleBoxEmpty_blank")
TabContainer/styles/tab_disabled = SubResource("StyleBoxFlat_btn_disabled")

; ── HScrollBar ──
HScrollBar/styles/grabber = SubResource("StyleBoxFlat_scrollbar_grabber")
HScrollBar/styles/grabber_highlight = SubResource("StyleBoxFlat_scrollbar_grabber_hl")
HScrollBar/styles/grabber_pressed = SubResource("StyleBoxFlat_scrollbar_grabber_pressed")
HScrollBar/styles/scroll = SubResource("StyleBoxFlat_scrollbar_track")
HScrollBar/styles/scroll_focus = SubResource("StyleBoxEmpty_blank")

; ── VScrollBar ──
VScrollBar/styles/grabber = SubResource("StyleBoxFlat_scrollbar_grabber")
VScrollBar/styles/grabber_highlight = SubResource("StyleBoxFlat_scrollbar_grabber_hl")
VScrollBar/styles/grabber_pressed = SubResource("StyleBoxFlat_scrollbar_grabber_pressed")
VScrollBar/styles/scroll = SubResource("StyleBoxFlat_scrollbar_track")
VScrollBar/styles/scroll_focus = SubResource("StyleBoxEmpty_blank")
